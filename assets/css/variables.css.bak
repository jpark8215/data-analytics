:root {
    /* Color Palette - Premium & Modern */
    --clr-bg: #0f172a; /* Slate 900 */
    --clr-surface: #1e293b; /* Slate 800 */
    --clr-surface-alt: #334155; /* Slate 700 */
    
    --clr-text-main: #f8fafc; /* Slate 50 */
    --clr-text-muted: #94a3b8; /* Slate 400 */
    
    --clr-primary: #3b82f6; /* Blue 500 */
    --clr-primary-glow: rgba(59, 130, 246, 0.3);
    --clr-secondary: #10b981; /* Emerald 500 */
    --clr-accent: #8b5cf6; /* Violet 500 */
    
    /* Typography */
    --font-main: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-heading: 'Outfit', var(--font-main);
    
    /* Spacing & Sizing */
    --space-xs: 0.5rem;
    --space-s: 1rem;
    --space-m: 2rem;
    --space-l: 4rem;
    --space-xl: 8rem;
    
    --max-width: 1200px;
    --content-width: 700px; /* Optimal for reading */
    
    /* Effects */
    --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    --radius-s: 0.5rem;
    --radius-m: 0.75rem;
    --radius-l: 1rem;
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Base Reset */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    background-color: var(--clr-bg);
    color: var(--clr-text-main);
    font-family: var(--font-main);
    line-height: 1.6;
    overflow-x: hidden;
}

h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: 1.2;
    margin-bottom: var(--space-s);
    color: var(--clr-text-main);
}

a {
    color: var(--clr-primary);
    text-decoration: none;
    transition: var(--transition);
}

a:hover {
    color: var(--clr-secondary);
}

img {
    max-width: 100%;
    height: auto;
    display: block;
}

.container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-m);
}

/* Glassmorphism Utilities */
.glass {
    background: rgba(30, 41, 59, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow-lg);
}

/* Scrollbar Styling */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: var(--clr-bg);
}

::-webkit-scrollbar-thumb {
    background: var(--clr-surface-alt);
    border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--clr-primary);
}
